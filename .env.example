# ── WhatsApp Broadcaster — environment ──────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Meta WhatsApp Cloud API (SAME Meta app, DIFFERENT number/WABA) ---
# Reuse the App ID/Secret from your existing app; point these at the NEW number.
META_WA_ACCESS_TOKEN=                 # [REQUIRED] System-user token with whatsapp_business_messaging + management
META_WA_PHONE_NUMBER_ID=              # [REQUIRED] Phone Number ID of the NEW number (Meta → WhatsApp → API Setup)
META_WA_WABA_ID=                      # [REQUIRED] WhatsApp Business Account ID the new number belongs to
META_WA_WEBHOOK_VERIFY_TOKEN=         # [REQUIRED] Any random string; paste the same value in Meta webhook config
META_WA_WEBHOOK_SECRET=               # [REQUIRED] The Meta App Secret (same app) — verifies webhook signatures
META_WA_APP_ID=                       # [REQUIRED for media templates] Meta App ID — sample images/videos for template approval upload through it

# Daily send cap — stay safely under your messaging tier (1000/24h tier-1 → 900).
WA_DAILY_LIMIT=900
NEXT_PUBLIC_WA_DAILY_LIMIT=900
# Recipients attempted per cron tick / inline chunk.
WA_SEND_CHUNK=80

# --- AI Assistant (Google Gemini + RAG) ---
GEMINI_API_KEY=                       # [REQUIRED for AI] Google AI Studio key (aistudio.google.com/apikey)
GEMINI_CHAT_MODEL=gemini-2.5-flash    # reply generation model
GEMINI_EMBED_MODEL=gemini-embedding-001  # embedding model (output dim must match vector(768) in 0003_kb.sql)
LLM_BOT_ENABLED=true                  # global kill switch — 'false' stops all auto-replies
KNOWLEDGE_ROUTER_ENABLED=true         # FAQ/cache/memory router before RAG — 'false' = always RAG
# BOT_SYSTEM_PROMPT=                   # optional: override the default assistant system prompt

# --- Auth ---
ADMIN_USER=                           # [REQUIRED] admin login email/username
ADMIN_PASSWORD=                       # [REQUIRED] strong admin password (20+ chars)
ADMIN_JWT_SECRET=                     # [REQUIRED] 32+ char random string for signing admin sessions
BROADCAST_API_KEY=                    # [REQUIRED] Bearer token for the server-to-server /api/broadcast + /api/contacts + /api/events
CRON_SECRET=                          # [REQUIRED] Bearer token guarding /api/cron/process-queue

# --- CRM integration (LeadSquared → WhatsApp, SETUP.md §CRM) ---
CRM_API_KEY=                          # [REQUIRED for CRM] Bearer token for server-to-server /api/crm/send (LSQ webhooks/automations)
CRM_PANEL_TOKEN=                      # [REQUIRED for CRM] token gating the embeddable /crm/chat panel (LSQ custom tab URL)
# LeadSquared timeline sync — pushes every WhatsApp message onto the lead's LSQ activity history. Optional.
LSQ_ACCESS_KEY=                       # LSQ → My Profile → Settings → API and Webhooks
LSQ_SECRET_KEY=
LSQ_API_HOST=https://api-in21.leadsquared.com   # your LSQ region host
LSQ_ACTIVITY_CODE=                    # event code of a Custom Activity type (e.g. "WhatsApp Message") created in LSQ

# --- Supabase (NEW project, separate from the masterclass app) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=                 # service-role/secret key (server-only; bypasses RLS)

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://your-broadcaster.vercel.app
