# ── Alabs Connect (SaaS) — environment ──────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.
#
# This is the MULTI-TENANT SaaS. Its infrastructure is SEPARATE from the
# internal wa-broadcaster app: its own Supabase project, its own Meta app
# (a Tech Provider app), its own keys. Per-tenant credentials (each customer's
# WhatsApp number/token, their CRM keys) are NOT set here — they are collected
# via Embedded Signup / settings and stored ENCRYPTED per tenant (crypto.ts).

# --- Meta app (Tech Provider — onboards each tenant's OWN WABA) ---
# One platform-level app; tenants connect their own numbers through Embedded
# Signup. Do NOT put a single tenant's WABA token here.
META_APP_ID=                          # [REQUIRED] Meta app id (Tech Provider app)
META_APP_SECRET=                      # [REQUIRED] Meta app secret — verifies webhook signatures (X-Hub-Signature-256)
META_EMBEDDED_SIGNUP_CONFIG_ID=       # [REQUIRED] Embedded Signup configuration id (Meta → app → WhatsApp → Embedded Signup)
META_WEBHOOK_VERIFY_TOKEN=            # [REQUIRED] any random string; paste the same value in Meta webhook config
META_GRAPH_VERSION=v22.0              # Graph API version

# Embedded Signup (client-side popup) — public, safe to expose. Set once the app
# is an approved Tech Provider and the signup configurations exist. When unset,
# the portal hides the "Connect with Facebook" buttons (manual entry still works).
NEXT_PUBLIC_META_APP_ID=                       # same as META_APP_ID (public)
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=    # WhatsApp Embedded Signup config id
NEXT_PUBLIC_META_INSTAGRAM_CONFIG_ID=          # Instagram Embedded Signup config id
NEXT_PUBLIC_META_GRAPH_VERSION=v22.0

# Daily send cap per number — stay safely under the messaging tier.
WA_DAILY_LIMIT=900
NEXT_PUBLIC_WA_DAILY_LIMIT=900
WA_SEND_CHUNK=80                      # recipients attempted per cron tick / inline chunk

# --- AI Assistant (Google Gemini + RAG) — platform-level key ---
GEMINI_API_KEY=                       # [REQUIRED for AI] Google AI Studio key (aistudio.google.com/apikey)
GEMINI_CHAT_MODEL=gemini-2.5-flash    # reply generation model
GEMINI_EMBED_MODEL=gemini-embedding-001  # embedding model (dim must match vector(768) in 0003_kb.sql)
LLM_BOT_ENABLED=true                  # global kill switch — 'false' stops all auto-replies
KNOWLEDGE_ROUTER_ENABLED=true         # FAQ/cache/memory router before RAG — 'false' = always RAG

# --- Auth & secrets ---
ADMIN_USER=                           # [REQUIRED] platform owner login (default-tenant admin)
ADMIN_PASSWORD=                       # [REQUIRED] strong password (20+ chars)
ADMIN_JWT_SECRET=                     # [REQUIRED] 32+ char random string; signs session JWTs
SECRET_ENC_KEY=                       # [REQUIRED] 32+ char high-entropy key; encrypts per-tenant secrets at rest (AES-256-GCM)
BROADCAST_API_KEY=                    # [REQUIRED] Bearer token for server-to-server /api/broadcast + /api/contacts + /api/events
CRON_SECRET=                          # [REQUIRED] Bearer token guarding /api/cron/*

# --- Supabase (DEDICATED SaaS project — NOT the internal app's project) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=                 # service-role/secret key (server-only; bypasses RLS — app-layer tdb() is the guard)

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://app.your-saas-domain.com

# NOTE — per-tenant integrations (NOT global env):
#   * Each tenant's WhatsApp number + access token  → Embedded Signup → encrypted vault
#   * Each tenant's CRM (LeadSquared, etc.) keys     → tenant settings → encrypted vault
#   The internal app's META_WA_* and LSQ_*/CRM_* env vars are intentionally
#   removed here — they were a single hardcoded tenant.
